# =============================================================================
# Lexio — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env — ele está no .gitignore
#
# Para gerar strings seguras:
#   openssl rand -hex 32
#   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# --- LLM via OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-XXXXX
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
MODEL_TRIAGE=anthropic/claude-3.5-haiku
MODEL_MAIN=anthropic/claude-sonnet-4

# --- Ollama (Embeddings locais) ---
OLLAMA_URL=http://ollama:11434
EMBED_MODEL=mxbai-embed-large

# --- PostgreSQL ---
# OBRIGATORIO: defina uma senha forte (usada pelo docker-compose e DATABASE_URL)
POSTGRES_USER=lexio
POSTGRES_DB=lexio
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
DATABASE_URL=postgresql+asyncpg://lexio:TROQUE_POR_SENHA_FORTE_AQUI@postgres:5432/lexio

# --- Qdrant (Banco Vetorial) ---
QDRANT_URL=http://qdrant:6333
# OBRIGATORIO: defina uma chave forte para proteger o Qdrant
QDRANT_API_KEY=TROQUE_POR_CHAVE_FORTE_AQUI
QDRANT_COLLECTION=acervo_juridico
QDRANT_COLLECTIONS=acervo_juridico,memoria_pessoal

# --- DataJud (CNJ — Jurisprudência) ---
# Chave publica padrao do CNJ. Consulte: https://datajud-wiki.cnj.jus.br/api-publica/
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==
DATAJUD_URL=https://api-publica.datajud.cnj.jus.br/api_publica_tjrs/_search

# --- SearXNG (Pesquisa Web) ---
SEARXNG_URL=http://searxng:8080/search

# --- JWT Auth (OBRIGATORIO: gere com `openssl rand -hex 32`) ---
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_SEGURA_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Aplicação (OBRIGATORIO: gere com `openssl rand -hex 32`) ---
APP_NAME=Lexio
APP_VERSION=1.0.0
SECRET_KEY=TROQUE_POR_OUTRA_STRING_ALEATORIA_SEGURA_32_CHARS
CORS_ORIGINS=http://localhost:3000,https://seu-dominio.com.br

# --- Organizacao Padrao (criada no primeiro boot) ---
DEFAULT_ORG_NAME=Minha Organizacao
DEFAULT_ORG_SLUG=minha-org

# =============================================================================
# Configuracao do Frontend (build-time, passado via docker-compose args)
# Nao necessario quando usando Docker Compose — ja configurado no docker-compose.yml
# Para deploy manual ou CI/CD, defina no ambiente de build:
#   VITE_DEMO_MODE=false
#   VITE_BASE_PATH=/
# =============================================================================
