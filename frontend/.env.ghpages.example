# Copy this file to .env.ghpages and fill in your real values.
# NEVER commit .env.ghpages — it is listed in .gitignore.
# These values are used only for LOCAL builds targeting GitHub Pages.
# CI/CD reads them from GitHub Secrets (Settings → Secrets → Actions).

VITE_DEMO_MODE=false
VITE_BASE_PATH=/Lexio/
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
