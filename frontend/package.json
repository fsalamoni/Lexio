{
  "name": "lexio-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:smoke": "vite build --mode smoke",
    "audit:baseline": "node ../scripts/lexio-platform-audit-baseline.mjs",
    "audit:deep": "node ../scripts/lexio-platform-audit-deep-sweep.mjs",
    "audit:final": "node ../scripts/lexio-platform-audit-final-closeout.mjs",
    "audit:faults": "node ../scripts/lexio-platform-audit-fault-matrix.mjs",
    "audit:release": "node ../scripts/lexio-platform-audit-release-closeout.mjs",
    "audit:residuals": "node ../scripts/lexio-platform-audit-residual-summary.mjs",
    "audit:riskscan": "node ../scripts/lexio-platform-audit-risk-scan.mjs",
    "architecture:check": "node ../scripts/lexio-architecture-guardrails.mjs",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "preview:smoke": "vite preview --host 127.0.0.1 --port 4173",
    "smoke": "vite build --mode smoke && vite preview --host 127.0.0.1 --port 4173",
    "test": "vitest run",
    "test:presentation-v2": "vitest run src/lib/presentation-v2-regression-harness.test.ts src/demo/presentation-v2-golden-benchmark.test.ts src/lib/presentation-generation-pipeline-v2.test.ts src/lib/quality-evaluator.presentation-v2.test.ts src/components/PresentationV2BriefingModal.test.tsx src/components/artifacts/PresentationV2Viewer.test.tsx src/components/artifacts/ArtifactViewerModal.test.tsx src/components/artifacts/artifact-exporters.test.ts src/demo/notebook-data.test.ts src/pages/labs/presentation-v2-briefing-seed.test.ts src/pages/CostTokensPage.test.tsx",
    "test:presentation-v2:benchmark": "vitest run src/api/demo-interceptor.test.ts src/lib/presentation-v2-regression-harness.test.ts src/demo/presentation-v2-golden-benchmark.test.ts src/demo/notebook-data.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@tiptap/extension-color": "^3.22.4",
    "@tiptap/extension-highlight": "^3.20.0",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-subscript": "^3.22.4",
    "@tiptap/extension-superscript": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "axios": "^1.6.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.0",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "firebase": "^11.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.300.0",
    "mammoth": "^1.6.0",
    "pdfjs-dist": "^4.4.168",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.10.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.0",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vitest": "^2.1.9"
  }
}
