# Git LFS — Qdrant vector database binary files
Teses/**/*.bin filter=lfs diff=lfs merge=lfs -text
Teses/**/*.dat filter=lfs diff=lfs merge=lfs -text
Teses/**/*.idx filter=lfs diff=lfs merge=lfs -text
# WAL files excluded — they are transient runtime files (see .gitignore)
Teses/**/*.segment filter=lfs diff=lfs merge=lfs -text
Teses/**/*.hnsw filter=lfs diff=lfs merge=lfs -text
Teses/**/*.quantization filter=lfs diff=lfs merge=lfs -text
Teses/**/*.mmap filter=lfs diff=lfs merge=lfs -text
Teses/**/*.mappings filter=lfs diff=lfs merge=lfs -text
Teses/**/*.versions filter=lfs diff=lfs merge=lfs -text
Teses/**/*.deleted filter=lfs diff=lfs merge=lfs -text

# Catch-all for any other large binary files in Qdrant storage
Teses/**/*.bk filter=lfs diff=lfs merge=lfs -text

# Windows batch launchers MUST keep CRLF endings, or cmd.exe fails to run them.
# Mark as -text so git never normalizes them to LF (in clones or ZIP/archive exports).
*.cmd -text
*.bat -text
# Unix launchers must keep LF endings.
*.command text eol=lf
*.sh text eol=lf
# Zipped installers are binary.
*.zip binary
