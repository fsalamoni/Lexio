# =============================================================================
# Lexio — Variáveis de Ambiente para PRODUÇÃO
# Copie este arquivo para .env e preencha os valores reais
# =============================================================================

# --- LLM via OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-XXXXX
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
MODEL_TRIAGE=anthropic/claude-3.5-haiku
MODEL_MAIN=anthropic/claude-sonnet-4

# --- Ollama (Embeddings locais) ---
OLLAMA_URL=http://ollama:11434
EMBED_MODEL=mxbai-embed-large

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://lexio:lexio@postgres:5432/lexio

# --- Qdrant (Banco Vetorial) ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=lexio_qdrant_key_2026
QDRANT_COLLECTION=acervo_mprs
QDRANT_COLLECTIONS=acervo_mprs,memoria_pessoal

# --- DataJud (CNJ — Jurisprudência) ---
DATAJUD_API_KEY=your_datajud_api_key
DATAJUD_URL=https://api-publica.datajud.cnj.jus.br/api_publica_tjrs/_search

# --- SearXNG (Pesquisa Web) ---
SEARXNG_URL=http://searxng:8080/search

# --- JWT Auth (gere strings seguras: openssl rand -hex 32) ---
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_SEGURA_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Aplicação ---
APP_NAME=Lexio
APP_VERSION=1.0.0
SECRET_KEY=TROQUE_POR_OUTRA_STRING_ALEATORIA_SEGURA
CORS_ORIGINS=http://localhost:3000,https://seu-dominio.com.br

# --- Organização Padrão (criada no primeiro boot) ---
DEFAULT_ORG_NAME=MPRS — Producao Juridica
DEFAULT_ORG_SLUG=mprs-producao

# =============================================================================
# Configuracao do Frontend (build-time, passado via docker-compose args)
# Nao necessario quando usando Docker Compose — ja configurado no docker-compose.yml
# Para deploy manual ou CI/CD, defina no ambiente de build:
#   VITE_DEMO_MODE=false
#   VITE_BASE_PATH=/
# =============================================================================
