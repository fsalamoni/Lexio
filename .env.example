# =============================================================================
# Lexio — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env — ele está no .gitignore
#
# Para gerar strings seguras:
#   openssl rand -hex 32
#   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# --- LLM via OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-XXXXX
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
MODEL_TRIAGE=anthropic/claude-3.5-haiku
MODEL_MAIN=anthropic/claude-sonnet-4

# --- Ollama (Embeddings locais) ---
OLLAMA_URL=http://ollama:11434
EMBED_MODEL=mxbai-embed-large

# --- PostgreSQL ---
# OBRIGATORIO: defina uma senha forte (usada pelo docker-compose e DATABASE_URL)
POSTGRES_USER=lexio
POSTGRES_DB=lexio
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
DATABASE_URL=postgresql+asyncpg://lexio:TROQUE_POR_SENHA_FORTE_AQUI@postgres:5432/lexio

# --- Qdrant (Banco Vetorial) ---
QDRANT_URL=http://qdrant:6333
# OBRIGATORIO: defina uma chave forte para proteger o Qdrant
QDRANT_API_KEY=TROQUE_POR_CHAVE_FORTE_AQUI
QDRANT_COLLECTION=acervo_juridico
QDRANT_COLLECTIONS=acervo_juridico,memoria_pessoal

# --- DataJud (CNJ — Jurisprudência) ---
# Chave publica padrao do CNJ. Consulte: https://datajud-wiki.cnj.jus.br/api-publica/
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==
DATAJUD_URL=https://api-publica.datajud.cnj.jus.br/api_publica_tjrs/_search

# --- SearXNG (Pesquisa Web) ---
SEARXNG_URL=http://searxng:8080/search

# --- JWT Auth (OBRIGATORIO: gere com `openssl rand -hex 32`) ---
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_SEGURA_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Aplicação (OBRIGATORIO: gere com `openssl rand -hex 32`) ---
APP_NAME=Lexio
APP_VERSION=1.0.0
SECRET_KEY=TROQUE_POR_OUTRA_STRING_ALEATORIA_SEGURA_32_CHARS
CORS_ORIGINS=http://localhost:3000,https://seu-dominio.com.br

# --- Organizacao Padrao (criada no primeiro boot) ---
DEFAULT_ORG_NAME=Minha Organizacao
DEFAULT_ORG_SLUG=minha-org

# =============================================================================
# Configuracao do Frontend (build-time, passado via VITE_ env vars)
# Nao necessario quando usando Docker Compose — ja configurado no docker-compose.yml
# Para deploy manual ou CI/CD, defina no ambiente de build:
#   VITE_DEMO_MODE=false
#   VITE_BASE_PATH=/
# =============================================================================

# =============================================================================
# Firebase (necessário para deploy em Firebase Hosting com Auth real)
#
# Obtenha os valores no Console do Firebase:
#   https://console.firebase.google.com → Projeto → Configurações → Aplicativo Web
#
# No GitHub Actions, configure estes como Secrets (Settings → Secrets → Actions):
#   FIREBASE_API_KEY, VITE_ADMIN_EMAIL, FIREBASE_TOKEN (ou FIREBASE_SERVICE_ACCOUNT)
#
# O VITE_FIREBASE_AUTH_DOMAIN deve ser o domínio .firebaseapp.com do projeto
# (ex.: meu-projeto.firebaseapp.com). Isso garante que o popup do Google Sign-In
# use o handler /__/auth/handler servido diretamente pelo Firebase, sem
# interferência de headers CSP customizados do hosting.
# O domínio também precisa estar autorizado no Firebase Console em
# Authentication → Settings → Authorized Domains.
# =============================================================================
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=SEU_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=SEU_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=SEU_PROJECT_ID.firebasestorage.app
# Nota: projetos Firebase criados antes de outubro/2024 podem usar o domínio legado:
# VITE_FIREBASE_STORAGE_BUCKET=SEU_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# E-mail do usuário administrador inicial (recebe role=admin no primeiro login Google)
VITE_ADMIN_EMAIL=admin@seudominio.com.br
