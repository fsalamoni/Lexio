rules_version = '2';
// Lexio — Firestore Security Rules (produção)
// Projeto: hocapp-44760  |  App: LexIO  |  lexio.web.app

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    // Checks that the caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Checks that the caller has admin role stored in /users/{uid}
    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // The caller is accessing their own user document
    function isSelf(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ── /users/{userId} ───────────────────────────────────────────────────────
    // Users can read/write their own profile.
    // Admins can read all profiles (for management).
    match /users/{userId} {
      allow read:   if isSelf(userId) || isAdmin();
      allow create: if isSelf(userId) && isValidUserCreate();
      allow update: if isSelf(userId) && isValidUserUpdate();
      allow delete: if isAdmin();

      function isValidUserCreate() {
        let data = request.resource.data;
        return data.keys().hasAll(['email', 'full_name', 'role', 'created_at'])
          && data.role in ['admin', 'user']
          && data.email == request.auth.token.email;
      }

      function isValidUserUpdate() {
        // Users cannot change their own role
        return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
      }
    }

    // ── /settings/{document} ─────────────────────────────────────────────────
    // Platform settings (API keys, etc.) — admin-only.
    match /settings/{document} {
      allow read, write: if isAdmin();
    }

    // ── Default: deny everything else ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
