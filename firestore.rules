rules_version = '2';
// Lexio — Firestore Security Rules (produção)
// Projeto: hocapp-44760  |  App: LexIO  |  lexio.web.app

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    // Checks that the caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Checks that the caller has admin role stored in /users/{uid}
    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // The caller is accessing their own user document
    function isSelf(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ── /users/{userId} ───────────────────────────────────────────────────────
    // Users can read/write their own profile.
    // Admins can read all profiles (for management).
    match /users/{userId} {
      allow get:    if isSelf(userId) || isAdmin();
      allow list:   if isAdmin();
      allow create: if isSelf(userId) && isValidUserCreate();
      allow update: if isSelf(userId) && isValidUserUpdate();
      allow delete: if isAdmin();

      function isValidUserCreate() {
        let data = request.resource.data;
        return data.keys().hasAll(['email', 'full_name', 'role', 'created_at'])
          && data.role in ['admin', 'user']
          && data.email == request.auth.token.email;
      }

      function isValidUserUpdate() {
        // Users cannot change their own role
        return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
      }

      // ── /users/{userId}/profile/{doc} ────────────────────────────────────
      // Anamnesis / professional profile data — user can read/write their own.
      match /profile/{document} {
        allow read: if isSelf(userId) || isAdmin();
        allow write: if isSelf(userId);
      }

      // ── /users/{userId}/settings/{doc} ───────────────────────────────────
      // User-scoped API keys and model preferences — owner-only access.
      match /settings/{document} {
        allow read, write: if isSelf(userId);
      }

      // ── /users/{userId}/documents/{docId} ────────────────────────────────
      // User's generated documents — user can CRUD their own.
      match /documents/{docId} {
        allow read: if isSelf(userId) || isAdmin();
        allow write: if isSelf(userId);
      }

      // ── /users/{userId}/theses/{thesisId} ─────────────────────────────────
      // User's thesis bank — user can CRUD their own theses.
      match /theses/{thesisId} {
        allow read: if isSelf(userId) || isAdmin();
        allow write: if isSelf(userId);
      }

      // ── /users/{userId}/thesis_analysis_sessions/{sessionId} ─────────────
      // Historical thesis-analysis runs — owner read/write, admin read-only.
      match /thesis_analysis_sessions/{sessionId} {
        allow read: if isSelf(userId) || isAdmin();
        allow write: if isSelf(userId);
      }

      // ── /users/{userId}/acervo/{docId} ──────────────────────────────────
      // User's reference documents (acervo) — uploaded texts used as
      // knowledge base during document generation.  Owner-only access.
      match /acervo/{docId} {
        allow read: if isSelf(userId) || isAdmin();
        allow write: if isSelf(userId);
      }

      // ── /users/{userId}/research_notebooks/{notebookId} ──────────────
      // Research notebooks (Caderno de Pesquisa) — owner-only access.
      match /research_notebooks/{notebookId} {
        allow read: if isSelf(userId) || isAdmin();
        allow write: if isSelf(userId);
      }

      match /research_notebooks/{notebookId}/memory/{docId} {
        allow read: if isSelf(userId) || isAdmin();
        allow write: if isSelf(userId);
      }

      // ── /users/{userId}/sidecar_devices/{deviceId} ───────────────────
      // Locally paired helper devices. Owner can manage, admins read only
      // for operational diagnostics without receiving local credentials.
      match /sidecar_devices/{deviceId} {
        allow read: if isSelf(userId) || isAdmin();
        allow write: if isSelf(userId);
      }

      // ── /users/{userId}/chat_workspace_roots/{rootId} ────────────────
      // Roots/connectors the chat may bind to a specific conversation.
      match /chat_workspace_roots/{rootId} {
        allow read: if isSelf(userId) || isAdmin();
        allow write: if isSelf(userId);
      }

      // ── /users/{userId}/chat_conversations/{conversationId} ──────────
      // Chat orchestrator conversations (page /chat) — owner-only.
      // Admins inherit read-only access via the collectionGroup rule below
      // for aggregated platform analytics.
      match /chat_conversations/{conversationId} {
        allow read: if isSelf(userId) || isAdmin();
        allow write: if isSelf(userId);

        // Each conversation owns a `turns` subcollection with one document
        // per user/assistant exchange, including the orchestration trail.
        match /turns/{turnId} {
          allow read: if isSelf(userId) || isAdmin();
          allow write: if isSelf(userId);
        }

        match /workspace_bindings/{bindingId} {
          allow read: if isSelf(userId) || isAdmin();
          allow write: if isSelf(userId);
        }

        match /sidecar_commands/{commandId} {
          allow read: if isSelf(userId) || isAdmin();
          allow write: if isSelf(userId);
        }

        match /approvals/{approvalId} {
          allow read: if isSelf(userId) || isAdmin();
          allow write: if isSelf(userId);
        }

        // Audit is append-only for the owner; entries can be read but never
        // modified or deleted through the client after creation.
        match /audit/{auditId} {
          allow read: if isSelf(userId) || isAdmin();
          allow create: if isSelf(userId);
          allow update, delete: if false;
        }
      }
    }

    // ── Collection group access for platform analytics ──────────────────────
    // The admin dashboard reads user operational data across all users through
    // collectionGroup queries. These rules are intentionally admin-read-only.
    match /{path=**}/documents/{docId} {
      allow read: if isAdmin();
    }

    match /{path=**}/theses/{thesisId} {
      allow read: if isAdmin();
    }

    match /{path=**}/thesis_analysis_sessions/{sessionId} {
      allow read: if isAdmin();
    }

    match /{path=**}/acervo/{docId} {
      allow read: if isAdmin();
    }

    match /{path=**}/research_notebooks/{notebookId} {
      allow read: if isAdmin();
    }

    match /{path=**}/research_notebooks/{notebookId}/memory/{docId} {
      allow read: if isAdmin();
    }

    match /{path=**}/chat_conversations/{conversationId} {
      allow read: if isAdmin();
    }

    match /{path=**}/chat_conversations/{conversationId}/turns/{turnId} {
      allow read: if isAdmin();
    }

    match /{path=**}/chat_conversations/{conversationId}/sidecar_commands/{commandId} {
      allow read: if isAdmin();
    }

    match /{path=**}/chat_conversations/{conversationId}/approvals/{approvalId} {
      allow read: if isAdmin();
    }

    match /{path=**}/chat_conversations/{conversationId}/audit/{auditId} {
      allow read: if isAdmin();
    }

    // ── /settings/{document} ─────────────────────────────────────────────────
    // Platform settings (API keys, etc.) — admin-only.
    match /settings/{document} {
      allow read, write: if isAdmin();
    }

    // ── Default: deny everything else ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
